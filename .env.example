# Amazon FBM Automation — Environment Variables
# Копирай този файл в .env и попълни стойностите
# НИКОГА не качвай .env в git!

# Google Sheets
CENTRAL_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS_FILE=credentials.json
DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# Amazon SP-API
SP_API_REFRESH_TOKEN=your_refresh_token
SP_API_CLIENT_ID=your_client_id
SP_API_CLIENT_SECRET=your_client_secret
SP_API_AWS_ACCESS_KEY=your_aws_access_key
SP_API_AWS_SECRET_KEY=your_aws_secret_key
SP_API_ROLE_ARN=arn:aws:iam::XXXX:role/SP-API-Role
SP_API_SELLER_ID=your_seller_id
