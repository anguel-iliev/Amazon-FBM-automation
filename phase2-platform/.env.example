# AMZ Retail Platform — Environment Variables
# Копирай в .env и попълни стойностите
# НИКОГА не качвай .env в git!

APP_URL=https://amz-retail.tnsoft.eu
APP_DEBUG=false

# ─────────────────────────────────────────────────────────────────
# SMTP (Gmail App Password)
#
# Стъпки за генериране на Gmail App Password:
#   1. Влез в https://myaccount.google.com
#   2. Security → 2-Step Verification (трябва да е включена!)
#   3. Scroll надолу → App passwords
#   4. Select app: Mail  |  Select device: Other (Custom name) → "AMZ Retail"
#   5. Натисни Generate → получаваш 16-символна парола (xxxx xxxx xxxx xxxx)
#   6. Копирай я ТУК (без интервалите):
#
# SMTP_PASS=abcdabcdabcdabcd
# ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tnsoftsales@gmail.com
SMTP_PASS=your_16char_app_password_here
SMTP_FROM=tnsoftsales@gmail.com
SMTP_FROM_NAME=AMZ Retail

# ─────────────────────────────────────────────────────────────────
# Google Drive / Sheets
# ─────────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=1Wch88u5tZApf5UOXzeH9AO7TETXGKYnT
GOOGLE_SHEET_ID=
