Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to sensitive directories
RewriteRule ^(src|data|cron)/ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^\.user\.ini - [F,L]

# Route all PHP requests through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # CRITICAL: Prevent ALL caching of dynamic pages
    # This ensures protected pages are never served from browser/proxy cache
    Header always set Cache-Control "no-store, no-cache, must-revalidate, private, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"

    # Exception: allow caching of static assets
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|woff|woff2|svg)$">
        Header set Cache-Control "public, max-age=86400"
        Header unset Pragma
        Header unset Expires
    </FilesMatch>
</IfModule>
